{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Active users + uptime + workers per WOS Autopilot user. Powered by OTLP metrics from the bot — counts distinct `sub` over a recent window for the headline 'how many are online' figure.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "id": 1,
      "title": "Active users (last 5m)",
      "description": "Count of distinct license subjects (emails) that emitted a heartbeat in the last 5 minutes. The headline 'how many users are online right now' number.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "blue", "value": 10 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(count by(sub) (wos_bot_heartbeat[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Active workers (total)",
      "description": "Sum of running worker subprocesses across all users. Scheduler excluded — this is 'how many emulators are being driven'.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "blue", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(wos_workers_active)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Median bot uptime",
      "description": "Median of bot uptime across active users. Use the distribution panel below for the long tail.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "quantile(0.5, wos_bot_uptime_seconds)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Restart rate (5m)",
      "description": "Worker / scheduler restarts per second over the last 5 minutes — high values mean a user's bot is crash-looping.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          },
          "unit": "ops"
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(wos_bot_restarts_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active users over time",
      "description": "Headline 'online users' metric over the dashboard's time range. 5-minute sliding window per data point.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "spanNulls": true
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(count by(sub) (wos_bot_heartbeat[5m]))",
          "legendFormat": "active users",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Workers active per user",
      "description": "Per-user emulator count, stacked. Tall stacks = multi-account farmers; flat ones = single-account users.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "stacking": { "mode": "normal", "group": "A" },
            "fillOpacity": 30
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "wos_workers_active",
          "legendFormat": "{{sub}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Uptime distribution (live)",
      "description": "Latest uptime per active host. Shows whether your fleet is 'fresh restarts' or 'long-runners'.",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "wos_bot_uptime_seconds",
          "legendFormat": "{{sub}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Restarts by process",
      "description": "Aggregate counts of how often the supervisor re-spawns a dead child. ``process_name=scheduler`` vs ``worker-<id>`` tells you where the fleet's instability sits.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by(process_name) (increase(wos_bot_restarts_total[$__range]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "License gate failures",
      "description": "Bots that tried to start without a valid license. ``reason`` splits ``missing`` / ``expired`` / ``machine_mismatch`` / ``invalid``; ``fingerprint`` tells you which host to follow up with.",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by(fingerprint, reason) (increase(wos_license_gate_failures_total[$__range]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["wos-autopilot", "telemetry"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "grafanacloud-prom", "value": "grafanacloud-prom" },
        "label": "Prometheus datasource",
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "WOS Autopilot — users & telemetry",
  "uid": "wos-autopilot-telemetry",
  "version": 1,
  "weekStart": ""
}
