# --- Local IDE / agent (do not commit) ----------------------------------------
.claude/
.idea/
.vscode/
*.swp
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# --- Secrets / env ------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example
# License signing private key — generated by ``uv run gen-license-keypair``.
# Only the maintainer's host should have this; the public key under
# ``src/licensing/public_key.pem`` is committed and used for verification.
.secrets/
# Per-host license files imported via the UI. The directory is committed
# (with a .gitkeep) so the Docker bind mount has a target before first boot,
# but the actual license files are unique per machine and never shared.
license-data/*.json
!license-data/.gitkeep

# --- Python -------------------------------------------------------------------
.venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Ruff / pytest / type-check caches (repo root and subpackages)
**/.ruff_cache/
**/.pytest_cache/
**/.mypy_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
hypothesis/

# --- uv / packaging (keep uv.lock committed) ------------------------------------

# --- Node (Streamlit plugin frontends) ----------------------------------------
**/node_modules/

# --- Local DB / persisted player state (do not commit) --------------------------
db/*.yaml
db/state/

# --- Runtime / bot process ----------------------------------------------------
references/temporal/
# Live MCP/AI-Editor captures (per-step dumps); commit only rehearsal/fixtures/ for pytest.
**/rehearsal/*
!**/rehearsal/fixtures/
!**/rehearsal/fixtures/**
.cache/
.wos.nohup.log
.wos.pid
*.log

# --- Local tooling outputs (scripts, labeling bench, inference) -----------------
result/
.bench_crops/

