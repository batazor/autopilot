# --- Local IDE / agent (do not commit) ----------------------------------------
.claude/
.idea/
.vscode/
*.swp
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# --- Secrets / env ------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example
# Local secrets — never committed.
.secrets/
# Telemetry endpoint + auth header for Grafana Cloud OTLP. Maintainer-only:
# the public repo ships ``_telemetry_secrets.py.example`` and the real file
# is dropped in by the maintainer before the production Docker build. When
# absent, the runtime bootstrap leaves OTel in its no-op state.
src/config/_telemetry_secrets.py

