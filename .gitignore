# --- Local IDE / agent (do not commit) ----------------------------------------
.claude/
.idea/
.vscode/
*.swp
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# --- Secrets / env ------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example
# License signing private key — generated by ``uv run gen-license-keypair``.
# Only the maintainer's host should have this; the public key under
# ``src/licensing/public_key.pem`` is committed and used for verification.
.secrets/
# Telemetry endpoint + auth header for Grafana Cloud OTLP. Maintainer-only:
# the public repo ships ``_telemetry_secrets.py.example`` and the real file
# is dropped in by the maintainer before the production Docker build. When
# absent, the runtime bootstrap leaves OTel in its no-op state.
src/config/_telemetry_secrets.py
# Per-host license files imported via the UI. The directory is committed
# (with a .gitkeep) so the Docker bind mount has a target before first boot,
# but the actual license files are unique per machine and never shared.
license-data/*.json
license-data/*.jwt
license-data/*.bak
license-data/host-id
!license-data/.gitkeep

# --- Python -------------------------------------------------------------------
.venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Ruff / pytest / type-check caches (repo root and subpackages)
**/.ruff_cache/
**/.pytest_cache/
**/.mypy_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
hypothesis/

# --- uv / packaging (keep uv.lock committed) ------------------------------------

# --- Node (Streamlit plugin frontends) ----------------------------------------
**/node_modules/

# --- Local DB / persisted player state (do not commit) --------------------------
db/*.yaml
db/state/

# --- Runtime / bot process ----------------------------------------------------
.next/
temporal/
.tmp_ocr/
runs/
captures/
# Live MCP/AI-Editor captures (per-step dumps); commit only rehearsal/fixtures/ for pytest.
**/rehearsal/*
!**/rehearsal/fixtures/
!**/rehearsal/fixtures/**
.cache/
.wos.nohup.log
.wos.pid
*.log

# --- Local tooling outputs (scripts, labeling bench, inference) -----------------
result/
.bench_crops/

# Signed licence files (raw JWTs) — must never be committed.
*.licence.jwt
*.licence.json
*.wos-license.json

# Dreamscape Memory module scene DB — the COMMITTED source of truth for scenes.
# Seeded once via tools/import_maps.py, then hand-edited by operators (points,
# galleries, practice-level); those edits live ONLY here, so the .db is tracked.
# The WAL/SHM sidecars are transient — never commit them (checkpoint before add).
games/wos/events/dreamscape_memory/scenes.db-wal
games/wos/events/dreamscape_memory/scenes.db-shm

# Plaintext backups left by scripts/encrypt_databases.py. They hold the
# UNENCRYPTED data the SQLCipher migration just protected — never commit them.
*.plaintext.bak
src/modules/radar/radar_corner_ref.yaml
