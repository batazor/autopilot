**/rehearsal/*
!**/rehearsal/fixtures/
!**/rehearsal/fixtures/**
.cache/
.wos.nohup.log
.wos.pid
*.log

# --- Local tooling outputs (scripts, labeling bench, inference) -----------------
result/
.bench_crops/

# Dreamscape Memory module scene DB — the COMMITTED source of truth for scenes.
# Seeded once via tools/import_maps.py, then hand-edited by operators (points,
# galleries, practice-level); those edits live ONLY here, so the .db is tracked.
# The WAL/SHM sidecars are transient — never commit them (checkpoint before add).
games/wos/events/dreamscape_memory/scenes.db-wal
games/wos/events/dreamscape_memory/scenes.db-shm

# Encrypted backups left by scripts/decrypt_databases.py when it converts an
# old SQLCipher DB to plain SQLite in place — never commit them.
*.encrypted.bak
src/modules/radar/radar_corner_ref.yaml

# Astro-generated type stubs (recreated by `astro sync` / dev server).
.astro/
