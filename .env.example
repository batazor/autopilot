# Template for ``.env`` (which is gitignored — copy this file and fill in values).
#
# Loading: every entry point auto-loads this file via ``config/env_loader.py``
# (uses ``python-dotenv``, ``override=False`` so OS env always wins). No
# ``set -a; source .env`` dance needed — just ``uv run bot`` / ``uv run play``.
#
# docker compose — also auto-loads ``.env`` from the directory containing
# docker-compose.yml; the variables become available for ``${VAR}``
# interpolation but must still be passed into the ``bot`` service via
# ``environment:`` to reach the container's process env.

# --- Local OCR ---------------------------------------------------------------
# OCR runs in-process through the local Tesseract CLI with eng.traineddata.
WOS_OCR_LANG=eng
WOS_TESSERACT_CMD=tesseract
# Optional tessdata directory containing eng.traineddata.
TESSDATA_PREFIX=

# --- Object-detection inference (Roboflow inference server) ------------------
# Used by feature debuggers that locate objects a fixed template can't match
# (Fishing Tournament fish detector → model find-fish-ssnpa/6). Run the sidecar
# with ``docker compose up -d inference``. The server pulls model weights on
# first request using ROBOFLOW_API_KEY (cached in the inference_cache volume).
ROBOFLOW_API_KEY=
# Inference server URL. Default matches the docker-compose sidecar on loopback.
# WOS_INFERENCE_URL=http://127.0.0.1:9001
# WOS_FISH_MODEL_ID=find-fish-ssnpa/6
# WOS_FISH_CONFIDENCE=0.4
# WOS_INFERENCE_TIMEOUT_SECONDS=30

# --- Grafana Cloud (logs → Loki, traces → Tempo, metrics → Mimir) ------------
# Grafana Cloud → Connections → "OTLP" → stack id + write-scope API token.
GRAFANA_CLOUD_STACK_ID=
GRAFANA_CLOUD_API_TOKEN=
# Stack region slug (see your gateway URL in Grafana Connections → OTLP).
GRAFANA_CLOUD_OTLP_REGION=eu-west-2

# When stack id + token are set, ``config/env_loader.apply_otel_env_defaults``
# points the bot at ``https://otlp-gateway-prod-<region>.grafana.net/otlp``
# and builds ``OTEL_EXPORTER_OTLP_HEADERS`` automatically (direct export).
#
# Disable telemetry entirely (stdout only):
# OTEL_SDK_DISABLED=true
#
# Override endpoint/headers manually (advanced — skips auto-wiring):
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-west-2.grafana.net/otlp
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(<stack_id>:<api_token>)>
#
# Optional: Queue history "Open in Tempo" links. Use `{trace_id}` as placeholder.
# WOS_TEMPO_TRACE_URL_TEMPLATE=https://<your-stack>.grafana.net/explore?left=...

# --- Optional knobs ---------------------------------------------------------
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.25
# WOS_OTEL_LOG_LEVEL=INFO
# OTEL_LOGS_EXPORTER=none
